#!/usr/bin/env bash
# SuperCtx discovery hook.
# Runs at SessionStart. Read-only: this never writes anything.

set -euo pipefail

# Safely check if CLAUDE_PLUGIN_ROOT is set
if [[ -z "${CLAUDE_PLUGIN_ROOT:-}" ]]; then
  exit 0
fi

# Run read-only detection using Python CLI, silencing stderr
state_json=$(PYTHONPATH="${CLAUDE_PLUGIN_ROOT}/scripts" python3 -m superctx status --detect 2>/dev/null || true)

if [[ -n "$state_json" ]]; then
  # Parse state, recommended_action, and candidates safely using python
  read -r state action candidates_csv <<<$(printf '%s' "$state_json" | python3 -c '
import json, sys
d = json.load(sys.stdin)
state = d.get("state", "not_candidate")
action = d.get("recommended_action", "none")
candidates = d.get("candidates", [])
print(state, action, ",".join(candidates))
' 2>/dev/null || true)

  if [[ "$state" == "managed_healthy" ]]; then
    cat <<'EOF'
SuperCtx is active. `.ctx/SUPERCTX.md` is the canonical shared project context. Registered tool instruction files are generated shims pointing to it. Use `/superctx:status` to check health.
EOF
  elif [[ "$state" == "managed_needs_repair" ]]; then
    if [[ "$action" == "repair" ]]; then
      cat <<'EOF'
SuperCtx is active, but the installation has broken or missing shims. Run `/superctx:status` and `/superctx:sync` to check and repair.
EOF
    else
      cat <<'EOF'
SuperCtx is present, but the configuration manifest is missing or invalid. Run `/superctx:status` to inspect.
EOF
    fi
  elif [[ "$state" == "managed_legacy" ]]; then
    cat <<'EOF'
SuperCtx is present, but some instruction files are legacy and not yet fully migrated. Treat this as a migration state: inspect with `/superctx:status`, preserve existing instruction contents, and do not run setup or remove `.ctx` without explicit user-approved migration steps.
EOF
  elif [[ "$state" == "candidate_repo" ]]; then
    # Format candidate file list for the agent
    candidate_list=$(printf '%s' "$candidates_csv" | python3 -c '
import sys
paths = sys.stdin.read().strip().split(",")
print("\n".join("- " + p for p in paths if p))
' 2>/dev/null || true)
    printf 'SuperCtx setup opportunity: This repository has agent instruction files but no shared context hub.\n\nDetected files:\n%s\n\nOffer to set up one shared context hub. Explain that this will:\n- create `.ctx/SUPERCTX.md` as the canonical project context\n- back up the originals under `.ctx/sources/`\n- replace the live instruction files with generated shims pointing to the hub\n\nAsk for explicit consent before running setup. Do not run `/superctx:init` until the user confirms. After consent, run `/superctx:init`.\n' "$candidate_list"
  fi
fi
